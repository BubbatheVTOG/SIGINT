{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama:josh.qwen3-coder-8b-32k-think-tool-92tps:latest",
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://192.168.1.5:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "gemma3:latest": {
          "name": "Gemma3 (local)"
        },
        "josh.qwen3-coder-8b-32k-think-tool-92tps:latest": {
          "name": "Qwen3 Coder (remote)"
        }
      }
    }
  },
  "mcp": {
    "linux": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "quay.io/redhat-services-prod/rhel-lightspeed-tenant/linux-mcp-server:latest"],
      "enabled": true
    }
  }
}
